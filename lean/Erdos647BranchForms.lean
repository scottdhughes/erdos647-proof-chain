/-- All 82 closed residues have unsatisfiable branch forms.
    Discharges the sorry in Erdos647ReductionChain. -/
theorem closed_residue_all_branches (r : ℕ)
    (hr : r ∈ Erdos647SieveCertificate.survivingResidues)
    (hhard : r ∉ Erdos647ResidueSets.openResidues14Literal) :
    ∀ c : Fin 30, ∀ u, ¬ SatisfiesBudgets (branchForms r c) u := by
  -- Step 1: Convert hr to membership in literal Finset
  rw [survivingResidues_eq] at hr
  -- Step 2: Unfold survivingLiteral to get disjunction r = v₁ ∨ r = v₂ ∨ ...
  simp only [survivingLiteral, Erdos647ResidueSets.openResidues14Literal,
    Finset.mem_insert, Finset.mem_singleton] at hr hhard
  -- Step 3: Case analysis over all 96 surviving residues
  rcases hr with rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl
